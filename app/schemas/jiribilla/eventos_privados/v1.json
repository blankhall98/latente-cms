{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latente.app/schemas/jiribilla/eventos_privados/v1.json",
  "title": "Jiribilla - Eventos Privados v1",
  "type": "object",
  "x-ui": {
    "label": "Eventos Privados",
    "order": ["mainText", "secondaryText", "image1", "image2", "image3"]
  },
  "properties": {
    "mainText": {
      "type": "string",
      "x-ui": {
        "label": "Main Text",
        "textarea": true
      }
    },
    "secondaryText": {
      "type": "string",
      "x-ui": {
        "label": "Secondary Text",
        "textarea": true
      }
    },
    "image1": { "$ref": "#/$defs/Image", "x-ui": { "label": "Image 1" } },
    "image2": { "$ref": "#/$defs/Image", "x-ui": { "label": "Image 2" } },
    "image3": { "$ref": "#/$defs/Image", "x-ui": { "label": "Image 3" } }
  },
  "required": ["mainText", "secondaryText", "image1", "image2", "image3"],
  "$defs": {
    "Image": {
      "type": "object",
      "x-ui": { "label": "Image" },
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "x-ui": {
            "label": "Image URL",
            "widget": "image",
            "preview": true,
            "placeholder": "Upload or paste image URL"
          }
        },
        "alt": {
          "type": "string",
          "x-ui": { "label": "Alt Text" }
        }
      },
      "required": ["url"]
    }
  }
}
