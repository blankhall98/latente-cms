{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://latente.app/schemas/jiribilla/equipo/v1.json",
  "title": "Jiribilla - Equipo v1",
  "type": "object",
  "x-ui": {
    "label": "Equipo",
    "order": ["mainText", "secondaryText", "gallery", "bottomText"]
  },
  "properties": {
    "mainText": {
      "type": "string",
      "x-ui": {
        "label": "Main Text",
        "textarea": true
      }
    },
    "secondaryText": {
      "type": "string",
      "x-ui": {
        "label": "Secondary Text",
        "textarea": true
      }
    },
    "gallery": {
      "type": "array",
      "x-ui": {
        "label": "Gallery",
        "addLabel": "Add Image",
        "help": "Upload, reorder, and delete gallery images."
      },
      "items": { "$ref": "#/$defs/Image" }
    },
    "bottomText": {
      "type": "string",
      "maxLength": 40,
      "x-ui": { "label": "Bottom Text" }
    }
  },
  "required": ["mainText", "secondaryText", "gallery", "bottomText"],
  "$defs": {
    "Image": {
      "type": "object",
      "x-ui": { "label": "Image" },
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "x-ui": {
            "label": "Image URL",
            "widget": "image",
            "preview": true,
            "placeholder": "Upload or paste image URL"
          }
        },
        "alt": {
          "type": "string",
          "x-ui": { "label": "Alt Text" }
        }
      },
      "required": ["url"]
    }
  }
}
